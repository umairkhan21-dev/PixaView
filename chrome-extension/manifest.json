{
  "manifest_version": 3,
  "name": "PixaView Responsive Tester",
  "description": "Open the current site in PixaView to check responsiveness across devices.",
  "version": "1.0.0",
  "minimum_chrome_version": "114",
  "permissions": [
    "tabs"
  ],
  "action": {
    "default_title": "PixaView Responsive Tester",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
